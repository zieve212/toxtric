# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments / conda
.venv/
venv/
env/

# VS Code settings (personal, not project)
.vscode/

# Claude Code local settings (personal, not project)
.claude/settings.local.json

# OS junk
